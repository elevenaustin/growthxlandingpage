<IfModule mod_rewrite.c>
  RewriteEngine On

  # Exclude physical files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Exclude static assets and script entrypoints explicitly (supports root or subfolder deployments)
  RewriteCond %{REQUEST_URI} (assets/|results/|api.php|check.php|logo.jpg|favicon.ico)
  RewriteRule ^ - [L]

  # Route everything else to index.php
  RewriteRule . index.php [L]
</IfModule>
